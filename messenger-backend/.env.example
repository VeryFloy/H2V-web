# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/h2v

# ─── Encryption (OTP/Auth) ─────────────────────────────────────────────────────
# ENCRYPTION_KEY: 64 hex chars (32 bytes) — AES-256-GCM для шифрования email
# HASH_SECRET: HMAC-SHA256 секрет для emailHash (поиск пользователей по email)
ENCRYPTION_KEY=
HASH_SECRET=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins. If unset, dev allows all; production blocks all.
CORS_ORIGIN=http://localhost:5173

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
SMTP_USER=donotreply@h2von.com

# ─── S3 Object Storage (optional, falls back to local disk) ──────────────────
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:donotreply@h2von.com
BASE_URL=http://localhost:3000

# ─── APNs (Apple Push — iOS) ─────────────────────────────────────────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=app.storm954.quinoa167
APNS_KEY_PATH=
APNS_KEY_CONTENT=
